# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# WordPress Database Configuration
WORDPRESS_DB_HOST=your_wordpress_host
WORDPRESS_DB_PORT=3306
WORDPRESS_DB_USER=your_db_username
WORDPRESS_DB_PASSWORD=your_db_password
WORDPRESS_DB_NAME=your_db_name
WORDPRESS_URL_TABLE=wp_custom_urls
WORDPRESS_TABLE_PREFIX=wp_

# Qdrant Configuration
QDRANT_HOST=qdrant
QDRANT_PORT=6333
COLLECTION_NAME=medicaloptics_content

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8033

# Embedding Processing Configuration (for handling large datasets)
EMBEDDING_BATCH_SIZE=10           # Number of items to process concurrently
EMBEDDING_CHUNK_SIZE=50           # Number of items per chunk to prevent timeouts
EMBEDDING_MAX_RETRIES=3           # Number of retries for failed embeddings
EMBEDDING_RETRY_DELAY=1.0         # Base delay between retries (seconds)
EMBEDDING_RATE_LIMIT_DELAY=0.1    # Delay between API calls to respect rate limits

# Production Settings (for Gunicorn)
GUNICORN_TIMEOUT=3600             # Worker timeout in seconds (1 hour)
GUNICORN_WORKERS=2                # Number of worker processes
GUNICORN_KEEPALIVE=30             # Keep-alive timeout
GUNICORN_MAX_REQUESTS=1000        # Max requests per worker before restart
GUNICORN_GRACEFUL_TIMEOUT=300     # Graceful shutdown timeout 