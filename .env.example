OPENAI_API_KEY=
ENVIRONMENT=development

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=chatbot
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/chatbot
POSTGRES_PORT=5432

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_HTTP_PORT=6043
QDRANT_GRPC_PORT=6044

JWT_SECRET=change-me
JWT_EXPIRES_MINUTES=120
RUN_MIGRATIONS_ON_STARTUP=false

BOOTSTRAP_SUPERADMIN_EMAIL=superadmin@example.com
# Optional: pre-seed superadmin during initial migration. Leave empty to skip.
BOOTSTRAP_SUPERADMIN_PASSWORD_HASH=

BACKEND_PORT=8043
FRONTEND_PORT=3043
REACT_APP_API_URL=http://localhost:8043

# Public widget auth/policy (env-only for current phase)
# JSON object: {"widget_key":"tenant_uuid", ...}
WIDGET_EMBED_KEYS_JSON={}
# Require Origin header to be in WIDGET_ALLOWED_ORIGINS
WIDGET_REQUIRE_ORIGIN=false
# Comma-separated allowlist or * for any
WIDGET_ALLOWED_ORIGINS=*

# Optional tenant source defaults (can also be set per tenant in DB)
WORDPRESS_DB_HOST=
WORDPRESS_DB_PORT=3306
WORDPRESS_DB_USER=
WORDPRESS_DB_PASSWORD=
WORDPRESS_DB_NAME=
WORDPRESS_URL_TABLE=wp_custom_urls
WORDPRESS_TABLE_PREFIX=wp_
