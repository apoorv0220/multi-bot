OPENAI_API_KEY=
ENVIRONMENT=development

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=chatbot
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/chatbot
POSTGRES_PORT=5432

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_HTTP_PORT=6043
QDRANT_GRPC_PORT=6044

JWT_SECRET=change-me
JWT_EXPIRES_MINUTES=120
RUN_MIGRATIONS_ON_STARTUP=false

BOOTSTRAP_SUPERADMIN_EMAIL=superadmin@example.com
# Optional: pre-seed superadmin during initial migration. Leave empty to skip.
BOOTSTRAP_SUPERADMIN_PASSWORD_HASH=

BACKEND_PORT=8043
FRONTEND_PORT=3043
API_PORT=8043
REACT_APP_API_URL=http://localhost:8043
# Runtime config for static widget/embed pages (no rebuild required when changed)
WIDGET_BASE_URL=
PUBLIC_API_BASE_URL=

# Public widget auth/policy (env-only for current phase)
# JSON object: {"widget_key":"tenant_uuid", ...}
WIDGET_EMBED_KEYS_JSON={}
# Require Origin header to be in WIDGET_ALLOWED_ORIGINS
WIDGET_REQUIRE_ORIGIN=false
# Comma-separated allowlist or * for any
WIDGET_ALLOWED_ORIGINS=*

# Optional: country blocking — any MaxMind DB-format Country MMDB on disk.
# Open-source friendly default: DB-IP IP to Country Lite (CC BY 4.0):
#   python3 backend/scripts/download_dbip_country_lite.py -o data/geoip/dbip-country-lite.mmdb
# Docker: mount ./data/geoip -> /data/geoip and point here, e.g.:
# GEOIP_DB_PATH=/data/geoip/dbip-country-lite.mmdb
GEOIP_DB_PATH=

# Superadmin bootstrap (optional). Or create/update via:
# docker compose run --rm backend python scripts/create_superadmin.py --email you@example.com --password '...' --tenant-slug default-tenant

# Optional tenant source defaults (can also be set per tenant in DB)
WORDPRESS_DB_HOST=
WORDPRESS_DB_PORT=3306
WORDPRESS_DB_USER=
WORDPRESS_DB_PASSWORD=
WORDPRESS_DB_NAME=
WORDPRESS_URL_TABLE=wp_custom_urls
WORDPRESS_TABLE_PREFIX=wp_
